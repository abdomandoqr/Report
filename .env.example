# =============================================================================
# Database Reactivation Workflow — Environment Variables Template
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# API Keys (required for production)
# -----------------------------------------------------------------------------
# Anthropic API key for Claude AI (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Resend API key for email delivery (https://resend.com/)
RESEND_API_KEY=

# Instagram credentials for DM fallback
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# -----------------------------------------------------------------------------
# Sender Information
# -----------------------------------------------------------------------------
# The email address verified in Resend (must be domain-verified)
SENDER_EMAIL=hello@yourdomain.com

# Display name for the sender
SENDER_NAME=Your Business Name

# Physical mailing address (required for CAN-SPAM compliance)
SENDER_PHYSICAL_ADDRESS=123 Main Street, City, State 12345

# -----------------------------------------------------------------------------
# Configurable Thresholds
# -----------------------------------------------------------------------------
# Churn score thresholds for different offer tiers
# informational: 0.70 - 0.79 (new products/categories)
# bonus_points: 0.80 - 0.89 (reward points offer)
# discount: 0.90 - 1.00 (direct discount offer)
CHURN_THRESHOLD_INFO=0.70
CHURN_THRESHOLD_BONUS=0.80
CHURN_THRESHOLD_DISCOUNT=0.90

# -----------------------------------------------------------------------------
# Offer Settings
# -----------------------------------------------------------------------------
# Discount percentage for discount-tier offers
DISCOUNT_PCT=25

# Business type for prompt customization (gym | dental | coaching)
BUSINESS_TYPE=gym

# Campaign language (en | ar)
CAMPAIGN_LANGUAGE=en

# -----------------------------------------------------------------------------
# Google Sheets Integration (optional — falls back to CSV if empty)
# -----------------------------------------------------------------------------
# Spreadsheet ID from Google Sheets URL
# https://docs.google.com/spreadsheets/d/YOUR_SPREADSHEET_ID_HERE/edit
GOOGLE_SHEET_ID=

# Path to OAuth service account credentials JSON file
GOOGLE_CREDENTIALS_PATH=credentials.json

# -----------------------------------------------------------------------------
# Data Paths
# -----------------------------------------------------------------------------
# Path to customers CSV file (relative to project root)
CUSTOMERS_CSV_PATH=data/customers.csv

# Path to system log CSV file
SYSTEM_LOG_PATH=data/system_log.csv
